# Large generated artifacts — recreate by re-running pipeline
phase1/runs/*/residuals.npz
phase1/runs/*/frames.npz
phase1/data/background_model*.npz

# Raw Garmin/Polar RRI logs (kept on disk for debugging, not in repo)
phase1/phase1/output/
phase1/output/garmin_rri_*.csv
phase1/output/polar_rri_*.csv

# Python build artefacts
__pycache__/
*.pyc
*.pyo

# Local Mac-side analysis venv (task #80, EMD-signal) — Jetson uses
# ~/knightvision-hub/.venv/ as its real env via phase1/run.sh
.venv-local/

# Editor / OS
.DS_Store
*.swp
*~
.vscode/
.idea/

# SDK auto-generated logs (grows on every run)
phase1/Log/

# CubeEye raw depth recordings — large AVI + NPY files
# Replay from CSV logs only; raw frames stay on local disk
*.avi
*.npy
phase1/sim_output/

# Virtual environments
.venv/

# MVP simulation generated artefacts — all regenerated by
# phase1/simulation/run_smoke.sh (scene_build.py builds scene.blend
# procedurally; render.py writes frames; depth.py writes depth_out).
# intrinsics.json + smoke_report.json are NOT here — they are
# source-of-truth (calibration + smoke result) and stay tracked.
phase1/simulation/frames/
phase1/simulation/depth_out/
phase1/simulation/scene.blend
phase1/simulation/*.blend1
phase1/simulation/*.blend2
phase1/simulation/*.blend@
